{
  "$schema": "https://turborepo.com/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "check-contracts": {
      "dependsOn": ["^build"],
      "inputs": [
        "src/**/*.{ts,tsx}",
        "tsconfig.json",
        "../../packages/*-api/src/**/*.ts",
        "../../packages/*-api/dist/**/*.d.ts",
        "../../packages/remotes-types/index.d.ts"
      ]
    },
    "clean": {
      "cache": false
    }
  }
}
